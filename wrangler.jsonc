{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "watermelon-baskets",
  "main": "./worker/index.ts",
  "compatibility_date": "2026-04-07",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": [
      "/api/*"
    ],
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "keep_vars": true
}
